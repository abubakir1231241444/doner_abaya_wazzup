# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key

# ── OpenRouter (DeepSeek v3) ───────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-5

# ── SendPulse (WhatsApp) ───────────────────────────────────
SENDPULSE_CLIENT_ID=your_sendpulse_client_id
SENDPULSE_CLIENT_SECRET=your_sendpulse_client_secret

# ── Telegram — Бот Кассира ─────────────────────────────────
CASHIER_BOT_TOKEN=telegram_cashier_bot_token
CASHIER_TG_ID=123456789          # Telegram ID кассира/группы

# ── Telegram — Бот Курьеров ────────────────────────────────
COURIER_BOT_TOKEN=telegram_courier_bot_token

# ── Kaspi реквизиты (для валидации чека) ──────────────────
KASPI_MERCHANT_NAME=ИП ДОНЕР А
KASPI_MERCHANT_BIN=810927300891
KASPI_PAY_URL=https://pay.kaspi.kz/pay/z2xchz4o

# ── Настройки ─────────────────────────────────────────────
TZ=Asia/Oral                     # UTC+5 Актобе
WORK_HOUR_OPEN=10
WORK_HOUR_CLOSE=1                # 01:00 следующего дня
DELIVERY_COST=500
