# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ── OpenRouter (DeepSeek) ─────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=deepseek/deepseek-v3-20241226

# ── Wazzup (WhatsApp) ──────────────────────────────────────
# Получите в личном кабинете Wazzup -> Настройки -> API
WAZZUP_API_KEY=your-wazzup-api-key
WAZZUP_CHANNEL_ID=your-whatsapp-channel-uuid

# ── Telegram — Бот Кассира ─────────────────────────────────
CASHIER_BOT_TOKEN=123456789:ABCDEF...
CASHIER_TG_ID=12345678,87654321

# ── Telegram — Бот Курьеров ────────────────────────────────
COURIER_BOT_TOKEN=987654321:ZYXWVU...

# ── Kaspi реквизиты (для валидации чека) ──────────────────
KASPI_MERCHANT_NAME=Souffle Aktobe
KASPI_MERCHANT_BIN=990424351371
KASPI_PAY_URL=https://pay.kaspi.kz/pay/k7atxtn1

# ── Настройки ─────────────────────────────────────────────
TZ=Asia/Oral
WORK_HOUR_OPEN=10
WORK_HOUR_CLOSE=1
DELIVERY_COST=500
WEBHOOK_SECRET=your-internal-secret-key
